{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "apps/web/**",
      "packages/api/**",
      "packages/connectors/**",
      "packages/db/**",
      "packages/notifications/**",
      "packages/queue/**",
      "packages/storage/**",
      "packages/types/**",
      "packages/config/**",
      "package.json",
      "package-lock.json",
      "turbo.json",
      "railway.json"
    ],
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_20", "ffmpeg"]
        }
      }
    },
    "buildCommand": "npm install && npm run build --workspace=@postpilot/web"
  },
  "deploy": {
    "startCommand": "npm run start --workspace=@postpilot/web",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
